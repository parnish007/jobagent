# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example          # keep the documented example file
frontend/.env.local    # frontend secrets (NEXT_PUBLIC_*)
*.key
*.pem

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
pip-log.txt
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytype/
*.pyi.bak             # stub files emitted by generators (keep hand-written .pyi)

# ─── Alembic ─────────────────────────────────────────────────────────────────
# Keep migration scripts; ignore compiled bytecode inside the package
backend/alembic/__pycache__/

# ─── ML models (large binary files — never commit these) ─────────────────────
backend/models/
*.bin
*.safetensors
*.pt
*.pth
*.ckpt

# ─── Node / Next.js ──────────────────────────────────────────────────────────
node_modules/
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Lock files for package managers other than npm (uncomment the one you use)
# yarn.lock
# pnpm-lock.yaml
# bun.lockb

# ─── Testing & coverage ──────────────────────────────────────────────────────
# Python
.coverage
htmlcov/
.pytest_cache/
# JavaScript / TypeScript
coverage/
.nyc_output/
# Playwright
playwright-report/
test-results/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
celerybeat-schedule
celerybeat.pid

# ─── Docker volumes (local bind-mount data) ──────────────────────────────────
docker/postgres-data/
docker/redis-data/

# ─── IDE & editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.cursor/

# ─── OS artefacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Miscellaneous generated / temporary files ───────────────────────────────
*.bak
*.tmp
*.orig
job_agent.html
