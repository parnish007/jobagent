# =============================================================
# Job Agent — Environment Variables
# Copy to .env and fill in your values
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobagent

# --- Backend ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobagent
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-...          # Required — Claude Sonnet
OPENAI_API_KEY=                        # Optional — GPT-4o fallback

# --- Scraping ---
BRIGHT_DATA_API_KEY=                   # Optional — proxy rotation

# --- Observability ---
LANGFUSE_PUBLIC_KEY=                   # Optional — agent tracing
LANGFUSE_SECRET_KEY=                   # Optional
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
